{
  "version": 1,
  "description": "Single source of truth for agent read profiles, budgets, selectors, and structural caps. Profiles model what a given agent/task actually loads at startup; do not treat the union of all files as one mandatory read.",
  "profileSelection": {
    "defaultProfile": "direct",
    "chooseBroadOnlyWhen": [
      "release_or_production_posture_needed",
      "infrastructure_or_data_posture_needed",
      "shared_architecture_or_multi_silo_state_needed",
      "governance_work_needs_live_programme_state"
    ],
    "chooseColdWhen": [
      "new_or_returning_agent",
      "unfamiliar_area"
    ],
    "governanceAuditWithoutLiveState": "direct_or_cold_plus_relevant_governing_docs"
  },
  "delegationSelector": {
    "canonicalTriggerOwner": ".agents/skills/multiagent-coordination/SKILL.md#quick-decision",
    "useBrokerWhenAny": [
      "task_touches_15_or_more_files",
      "task_spans_3_or_more_silos",
      "task_has_repeated_slices_or_fanout",
      "user_requests_panel_or_multiagent_review",
      "broad_read_heavy_audit_or_review",
      "task_needs_variations_or_compare_approaches",
      "task_needs_second_model_opinion",
      "browser_research_visual_critique_or_notebook_synthesis"
    ],
    "stayLocalWhenAny": [
      "tiny_one_file_change",
      "sensitive_secret_or_credential_surface",
      "tightly_coupled_edit_cheaper_to_verify_locally"
    ],
    "router": ".agents/skills/multiagent-coordination/SKILL.md"
  },
  "primaryVerifierPolicy": {
    "codexLed": "codex_final_editor_verifier",
    "nonCodexPrimary": "primary_agent_self_verifies_locally",
    "delegateOutput": "advisory_until_primary_agent_verifies_against_local_sources"
  },
  "profiles": {
    "direct": {
      "use": "Small, familiar, sensitive, or tightly coupled work.",
      "files": ["AGENTS.md"],
      "budgetWords": 1100
    },
    "cold": {
      "use": "New/returning agent or unfamiliar area.",
      "files": ["AGENTS.md", ".agents/workflows/agent-onboarding.md"],
      "budgetWords": 1700
    },
    "broad": {
      "use": "Release, infrastructure, shared architecture, multi-silo, unclear live posture, or governance work that needs current programme state.",
      "files": ["AGENTS.md", ".planning/ACTIVE_CONTEXT_STATE.json"],
      "followupFiles": [
        {
          "path": ".planning/ACTIVE_CONTEXT.md",
          "readWhen": "human_context_or_source_map_detail_needed"
        },
        {
          "path": ".planning/llm-wiki/index.md",
          "readWhen": "source_discovery_needed"
        }
      ],
      "budgetWords": 2300
    },
    "injected": {
      "use": "Harness-injected dispatcher path.",
      "files": [".agents/rules/rules.md", "AGENTS.md"],
      "budgetWords": 1400
    },
    "claude": {
      "use": "Claude entry.",
      "files": ["CLAUDE.md", "AGENTS.md"],
      "budgetWords": 1200
    },
    "gemini": {
      "use": "Gemini or browser-agent entry.",
      "files": ["GEMINI.md", "AGENTS.md"],
      "budgetWords": 1200
    }
  },
  "aggregate": {
    "use": "Repo-hygiene aggregate of every always-read startup file. Not a single agent read; a drift ceiling.",
    "files": [
      "AGENTS.md",
      "CLAUDE.md",
      "GEMINI.md",
      ".agents/rules/rules.md",
      ".agents/workflows/agent-onboarding.md",
      ".planning/ACTIVE_CONTEXT_STATE.json"
    ],
    "budgetWords": 3000
  },
  "fileCaps": {
    ".agents/AGENT_BOOTSTRAP.json": { "maxWords": 900, "warnBytes": 8192, "failBytes": 12288 },
    "AGENTS.md": { "maxWords": 1100, "warnBytes": 8192, "failBytes": 12288 },
    ".agents/rules/rules.md": { "maxWords": 300 },
    ".agents/AGENT_SURFACES.md": { "maxWords": 350 },
    ".agents/workflows/agent-onboarding.md": { "maxWords": 650 },
    ".agents/workflows/gsd-planning.md": { "maxWords": 900 },
    ".agents/workflows/multi-agent-loop.md": { "maxWords": 1300, "failBytes": 12288 },
    ".agents/skills/multiagent-coordination/SKILL.md": { "maxWords": 1000 },
    "CLAUDE.md": { "maxWords": 120 },
    "GEMINI.md": { "maxWords": 120 },
    ".planning/ACTIVE_CONTEXT.md": { "warnBytes": 8192, "failBytes": 12288 },
    ".planning/ACTIVE_CONTEXT_STATE.json": { "warnBytes": 8192, "failBytes": 12288 },
    "docs/ADOPTION_GUIDE.md": { "maxWords": 700 },
    "docs/ARCHITECTURE.md": { "maxWords": 1500 },
    "docs/KNOWLEDGE.md": { "maxWords": 1500 }
  },
  "structure": {
    "hardStopsFile": "AGENTS.md",
    "hardStopsAnchor": "hard-stops",
    "hardStopsBeforeRouting": true,
    "bottomChecksumRequired": true,
    "bottomChecksumPattern": "SAFETY CHECKSUM",
    "machineBootstrap": ".agents/AGENT_BOOTSTRAP.json"
  }
}
